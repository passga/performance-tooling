# Example variables for AWS infrastructure (k3s server)

############################
# AWS
############################

aws_region = "eu-west-3"

aws_instance_type = "t3.small"
aws_key_name      = "my-ssh-key"

############################
# Networking
############################

# CIDR allowed to access SSH / Rancher (your public IP recommended)
admin_cidr = "x.x.x.x/32"
